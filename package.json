{
  "name": "safe-save-medical-center",
  "version": "1.0.0",
  "description": "Safe & Save Medical Center - Professional Pharmacy Inventory Management",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc && vite build",
    "lint": "tsc --noEmit",
    "obfuscate": "javascript-obfuscator ./dist/assets --output ./dist/assets --compact true",
    "preview": "vite preview",
    "start": "electron .",
    "package": "npm run build && npm run obfuscate && electron-builder --win",
    "dist": "npm run build && npm run obfuscate && electron-builder"
  },
  "keywords": [
    "pharmacy",
    "inventory",
    "medical",
    "electron"
  ],
  "author": "Safe & Save Dev Team",
  "license": "UNLICENSED",
  "dependencies": {
    "@google/genai": "^1.34.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dexie": "^3.2.4",
    "dexie-export-import": "^4.1.4",
    "dexie-react-hooks": "^1.1.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "googleapis": "^171.4.0",
    "html-to-image": "^1.11.13",
    "html2pdf.js": "^0.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^4.1.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.safesavemedicalcenter.app",
    "productName": "Safe & Save Medical Center",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Safe & Save"
    }
  }
}
